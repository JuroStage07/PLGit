rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /* ===================== HELPERS ===================== */
    function signedIn() {
      return request.auth != null;
    }

    function myUserDocPath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function isMyPartner(targetUid) {
      return signedIn()
        && exists(myUserDocPath())
        && get(myUserDocPath()).data.partnerUid == targetUid;
    }

    function isPartnerOfMe(userId) {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(userId))
        && get(/databases/$(database)/documents/users/$(userId)).data.partnerUid == request.auth.uid;
    }

    function isPartnerEitherWay(userId) {
      return isMyPartner(userId) || isPartnerOfMe(userId);
    }

    function onlyGroupFieldsChanged() {
      return request.resource.data.diff(resource.data).changedKeys()
        .hasOnly(['groupId', 'group', 'groupCreatedAt']);
    }

    function isGroupMember(groupId) {
      return signedIn()
        && exists(/databases/$(database)/documents/groups/$(groupId))
        && get(/databases/$(database)/documents/groups/$(groupId)).data.members is list
        && request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.members;
    }

    function isOnlyAcceptFieldsChanged() {
      return request.resource.data.diff(resource.data).changedKeys()
        .hasOnly(['accepted', 'acceptedAt', 'acceptedBy']);
    }

    function validApproveAction() {
      return (resource.data.accepted == false)
        && ('accepted' in request.resource.data)
        && (request.resource.data.accepted == true)
        && ('acceptedBy' in request.resource.data)
        && (request.auth.uid == request.resource.data.acceptedBy)
        && ('createdBy' in resource.data)
        && (request.auth.uid != resource.data.createdBy);
    }

    function onlySavedItemFieldsChanged() {
      return request.resource.data.diff(resource.data).changedKeys()
        .hasOnly(['name', 'price', 'updatedAt', 'updatedBy']);
    }

    function onlyListFieldsChanged() {
      return request.resource.data.diff(resource.data).changedKeys()
        .hasOnly([
          'name',
          'isDaily',
          'progress',
          'totalItems',
          'checkedItems',
          'spentCRC',
          'updatedAt',
          'updatedBy'
        ]);
    }

    function onlyListItemFieldsChanged() {
      return request.resource.data.diff(resource.data).changedKeys()
        .hasOnly([
          'name',
          'price',
          'quantity',
          'checked',
          'updatedAt',
          'updatedBy'
        ]);
    }

    /* ===================== USERS ===================== */
    match /users/{userId} {

      allow read: if signedIn()
        && (
          request.auth.uid == userId
          || isMyPartner(userId)
          || isPartnerOfMe(userId)
        );

      allow create: if signedIn()
        && request.auth.uid == userId;

      allow update: if signedIn()
        && (
          (
            request.auth.uid == userId
            && !(
              'partnerUid' in request.resource.data.diff(resource.data).changedKeys() ||
              'partnerUsuario' in request.resource.data.diff(resource.data).changedKeys() ||
              'partnerNombre' in request.resource.data.diff(resource.data).changedKeys() ||
              'partnerGenero' in request.resource.data.diff(resource.data).changedKeys() ||
              'partneredAt' in request.resource.data.diff(resource.data).changedKeys()
            )
          )
          ||
          (
            isPartnerEitherWay(userId)
            && onlyGroupFieldsChanged()
          )
        );

      allow delete: if false;

      /* ========== PARTNER REQUESTS ========== */
      match /partnerRequests/{senderUid} {
        allow read: if signedIn()
          && (request.auth.uid == userId || request.auth.uid == senderUid);

        allow create: if signedIn()
          && request.auth.uid == senderUid;

        allow delete: if signedIn()
          && (request.auth.uid == userId || request.auth.uid == senderUid);

        allow update: if false;
      }

      /* ========== CALENDAR NOTES (privado por usuario) ========== */
      match /calendarNotes/{dayId} {
        allow read, write: if signedIn()
          && request.auth.uid == userId;

        match /items/{itemId} {
          allow read, write: if signedIn()
            && request.auth.uid == userId;
        }
      }

      /* ========== MI SALDO LOGS (dueño escribe; pareja lee historial conjunto) ========== */
      match /miSaldoLogs/{logId} {
        allow read: if signedIn()
          && (
            request.auth.uid == userId
            || isPartnerEitherWay(userId)
          );

        allow create, delete: if signedIn()
          && request.auth.uid == userId;

        allow update: if false;
      }
    }

    /* ===================== GROUPS ===================== */
    match /groups/{groupId} {

      allow read: if isGroupMember(groupId);

      allow create: if signedIn()
        && request.resource.data.members is list
        && request.auth.uid in request.resource.data.members;

      allow update: if isGroupMember(groupId)
        && request.resource.data.members == resource.data.members;

      allow delete: if isGroupMember(groupId)
        && request.auth.uid == resource.data.createdBy;

      match /events/{eventId} {
        allow read, create, update, delete: if isGroupMember(groupId);
      }

      /* ========== REQUESTS (solicitudes) ========== */
      match /requests/{requestId} {
        allow read: if isGroupMember(groupId);

        allow create: if isGroupMember(groupId)
          && ('accepted' in request.resource.data)
          && request.resource.data.accepted == false
          && ('createdBy' in request.resource.data)
          && request.resource.data.createdBy == request.auth.uid;

        allow update: if isGroupMember(groupId)
          && isOnlyAcceptFieldsChanged()
          && validApproveAction();

        allow delete: if isGroupMember(groupId)
          && resource.data.accepted == false;
      }

      /* ========== SAVINGS (ahorros) ========== */
      match /savings/{savingId} {
        allow read: if isGroupMember(groupId);

        allow create: if isGroupMember(groupId)
          && ('accepted' in request.resource.data)
          && request.resource.data.accepted == false
          && ('createdBy' in request.resource.data)
          && request.resource.data.createdBy == request.auth.uid;

        allow update: if isGroupMember(groupId)
          && isOnlyAcceptFieldsChanged()
          && validApproveAction();

        allow delete: if isGroupMember(groupId)
          && resource.data.accepted == false;
      }

      /* ========== REBAJOS MENSUALES (doc del rebajo) ========== */
      match /monthlyRebates/{rebateId} {
        allow read: if isGroupMember(groupId);

        allow create: if isGroupMember(groupId)
          && ('accepted' in request.resource.data)
          && request.resource.data.accepted == false
          && ('createdBy' in request.resource.data)
          && request.resource.data.createdBy == request.auth.uid;

        allow update: if isGroupMember(groupId)
          && isOnlyAcceptFieldsChanged()
          && validApproveAction();

        allow delete: if isGroupMember(groupId)
          && resource.data.accepted == false;
      }

      /* ========== REBAJOS: estado mensual compartido (subcolección periods) ==========
         Ruta: groups/{groupId}/monthlyRebates/{rebateId}/periods/{periodKey}
         Match explícito (evita problemas con reglas solo anidadas). */
      match /monthlyRebates/{rebateId}/periods/{periodKey} {
        allow read: if isGroupMember(groupId);
        allow create, update: if isGroupMember(groupId);
        allow delete: if false;

        match /payments/{paymentId} {
          allow read: if isGroupMember(groupId);
          allow create: if isGroupMember(groupId)
            && request.resource.data.uid == request.auth.uid
            && request.resource.data.amount is number
            && request.resource.data.amount > 0;
          allow update, delete: if false;
        }
      }

      /* ========== CALENDAR NOTES (compartido por grupo) ========== */
      match /calendarNotes/{dayId} {
        allow read, create, update, delete: if isGroupMember(groupId);

        match /items/{itemId} {
          allow read, create, update, delete: if isGroupMember(groupId);
        }
      }

      /* ========== MI SALDO CONFIG ========== */
      match /miSaldoConfig/{docId} {
        allow read: if isGroupMember(groupId);
        allow create: if isGroupMember(groupId);
        allow update: if isGroupMember(groupId);
        allow delete: if false;
      }

      /* ========== ARTÍCULOS GUARDADOS DEL GRUPO ========== */
      match /savedItems/{itemId} {
        allow read: if isGroupMember(groupId);

        allow create: if isGroupMember(groupId)
          && ('createdBy' in request.resource.data)
          && request.resource.data.createdBy == request.auth.uid;

        allow update: if isGroupMember(groupId)
          && onlySavedItemFieldsChanged();

        allow delete: if isGroupMember(groupId);
      }

      /* ========== LISTAS DEL GRUPO ========== */
      match /lists/{listId} {
        allow read: if isGroupMember(groupId);

        allow create: if isGroupMember(groupId)
          && ('createdBy' in request.resource.data)
          && request.resource.data.createdBy == request.auth.uid;

        allow update: if isGroupMember(groupId)
          && onlyListFieldsChanged();

        allow delete: if isGroupMember(groupId);

        match /items/{itemId} {
          allow read: if isGroupMember(groupId);

          allow create: if isGroupMember(groupId)
            && ('createdBy' in request.resource.data)
            && request.resource.data.createdBy == request.auth.uid;

          allow update: if isGroupMember(groupId)
            && onlyListItemFieldsChanged();

          allow delete: if isGroupMember(groupId);
        }
      }
    }
  }
}
